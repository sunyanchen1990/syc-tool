{
  "name": "syc-tool",
  "version": "1.0.1",
  "description": "SYC-TOOL — Mac 桌面工具：天气、计算器、便签、剪贴板暂存",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "preview": "vite preview",
    "electron:compile": "tsc -p tsconfig.electron.json",
    "electron:dev": "npm run electron:compile && concurrently -k \"vite\" \"wait-on http://localhost:5173 && env -u ELECTRON_RUN_AS_NODE ./node_modules/.bin/electron .\"",
    "start": "npm run build:electron && env -u ELECTRON_RUN_AS_NODE ./node_modules/.bin/electron .",
    "build:electron": "tsc -p tsconfig.electron.json && vite build",
    "icons": "bash scripts/fetch-msyh.sh; node scripts/generate-icon.mjs && bash scripts/make-icon.sh",
    "pack": "(test -f build/icon.icns && test -f build/icon.png || npm run icons) && npm run build:electron && electron-builder --mac",
    "pack:cn": "npm run icons && npm run build:electron && ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ electron-builder --mac",
    "release:local": "bash scripts/release-local.sh",
    "install": "bash scripts/install.sh",
    "install:mac": "bash scripts/install-mac.sh",
    "install:release": "bash scripts/install-release.sh",
    "install:brew": "bash scripts/install-brew.sh",
    "website:capture": "bash scripts/capture-website-screenshots.sh"
  },
  "build": {
    "appId": "com.syc.tool",
    "productName": "SYC-TOOL",
    "icon": "build/icon.icns",
    "directories": {
      "output": "release"
    },
    "electronDist": "node_modules/electron/dist",
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.utilities",
      "identity": null,
      "gatekeeperAssess": false,
      "hardenedRuntime": false,
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "target": [
        "dmg",
        "zip"
      ],
      "extendInfo": {
        "CFBundleIconFile": "icon",
        "CFBundleIconName": "icon",
        "CFBundleVersion": "6",
        "CFBundleShortVersionString": "1.0.1",
        "NSLocationWhenInUseUsageDescription": "用于根据您的位置显示当地天气"
      }
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "src/assets/wallpapers",
        "to": "default-wallpapers",
        "filter": [
          "**/*"
        ]
      }
    ],
    "npmRebuild": false,
    "dmg": {
      "title": "${productName} ${version}",
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 140,
          "y": 210,
          "type": "file",
          "path": "build/安装 SYC-TOOL.command"
        },
        {
          "x": 400,
          "y": 210,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "systeminformation": "^5.31.6",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  }
}
